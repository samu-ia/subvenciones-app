{
  "name": "subvenciones-app",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "agents": "dotenvx run -f .env.local -- npx tsx scripts/agents/orchestrator.ts",
    "agents:watch": "dotenvx run -f .env.local -- npx tsx scripts/agents/orchestrator.ts --watch",
    "agents:add": "dotenvx run -f .env.local -- npx tsx scripts/agents/add-task.ts",
    "pipeline": "node scripts/pipeline-magistral.mjs",
    "pipeline:all": "node scripts/pipeline-magistral.mjs --all --workers 15",
    "pipeline:id": "node scripts/pipeline-magistral.mjs --id",
    "pipeline:ingesta": "node scripts/pipeline-magistral.mjs --fase ingesta --all",
    "pipeline:descarga": "node scripts/pipeline-magistral.mjs --fase descarga --all",
    "pipeline:extraccion": "node scripts/pipeline-magistral.mjs --fase extraccion_ia --all",
    "pipeline:normalizar": "node scripts/pipeline-magistral.mjs --fase normalizacion --all",
    "pipeline:validar": "node scripts/pipeline-magistral.mjs --fase validacion --all",
    "pdf": "node scripts/pipeline-pdf-real.mjs",
    "pdf:all": "node scripts/pipeline-pdf-real.mjs --all",
    "pdf:id": "node scripts/pipeline-pdf-real.mjs --id",
    "enrich": "node scripts/enrich-with-gemini.mjs",
    "matching": "node scripts/run-matching.mjs --all",
    "team": "npx tsx scripts/agents/langgraph/run.ts",
    "team:task": "npx tsx scripts/agents/langgraph/run.ts --task-id",
    "team:list": "npx tsx scripts/agents/langgraph/run.ts --list",
    "db:backup": "dotenvx run -f .env.local -- node scripts/backup-db.mjs",
    "db:restore": "dotenvx run -f .env.local -- node scripts/restore-db.mjs",
    "db:migrate": "dotenvx run -f .env.local -- node scripts/run-migration.js",
    "titulos": "dotenvx run -f .env.local -- node scripts/generate-titulos-comerciales.mjs",
    "prospectar": "node scripts/prospectar.mjs",
    "deep-review": "node scripts/deep-review.mjs",
    "loop": "node scripts/agent-loop.mjs",
    "loop:watch": "node scripts/agent-loop.mjs --watch",
    "improve": "node scripts/self-improve.mjs",
    "improve:watch": "node scripts/keep-alive.mjs",
    "improve:dry": "node scripts/self-improve.mjs --dry",
    "maestro": "dotenvx run -f .env.local -- node scripts/bucle-maestro.mjs",
    "maestro:dry": "dotenvx run -f .env.local -- node scripts/bucle-maestro.mjs --dry",
    "maestro:pipeline": "dotenvx run -f .env.local -- node scripts/bucle-maestro.mjs --pipeline-solo"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.41",
    "@anthropic-ai/claude-agent-sdk": "^0.2.84",
    "@anthropic-ai/sdk": "^0.81.0",
    "@langchain/core": "^1.1.36",
    "@langchain/langgraph": "^1.2.5",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.99.1",
    "@tiptap/extension-link": "^3.20.2",
    "@tiptap/react": "^3.20.2",
    "@tiptap/starter-kit": "^3.20.2",
    "ai": "^6.0.116",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "openai": "^6.29.0",
    "pdfjs-dist": "^5.5.207",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "shadcn": "^4.0.8",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.3.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "pg": "^8.20.0",
    "puppeteer": "^24.40.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
